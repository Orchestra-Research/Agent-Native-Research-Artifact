    "directory": "packages/ara-skills"
  },
  "homepage": "https://github.com/Orchestra-Research/Agent-Native-Research-Artifact-Init#readme",
  "bugs": {
    "url": "https://github.com/Orchestra-Research/Agent-Native-Research-Artifact-Init/issues"
